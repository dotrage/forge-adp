FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /orchestrator ./cmd/orchestrator

FROM alpine:3.19
RUN apk --no-cache add ca-certificates
COPY --from=builder /orchestrator /orchestrator
EXPOSE 19080
ENTRYPOINT ["/orchestrator"]
